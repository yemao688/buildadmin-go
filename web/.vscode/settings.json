{
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[vue]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "eslint.validate": ["javascript", "vue", "typescript"],

    // ==================== i18n Ally（VSCode 插件）配置 ====================
    "i18n-ally.localesPaths": ["src/lang"],
    "i18n-ally.pathMatcher": "{locale}.{ext}",
    "i18n-ally.keystyle": "nested",
    "i18n-ally.sourceLanguage": "zh-cn",
    "i18n-ally.displayLanguage": "zh-cn",
    "i18n-ally.enabledFrameworks": ["vue", "vue-sfc"],
    "i18n-ally.readonly": true,
    "i18n-ally.editor.preferEditor": false,
    "i18n-ally.namespace": false,
    "i18n-ally.annotationInPlace": true,
    "i18n-ally.enabledParsers": ["json"]
}
